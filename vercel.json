{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/build",
  "builds": [
    {
      "src": "api/package.json",
      "use": "@vercel/node@4"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*\\.css)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.js)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.json)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.png)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.jpg)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*\\.svg)$",
      "dest": "/$1"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
