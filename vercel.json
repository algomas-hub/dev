{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build && cp public/*.{png,jpg,jpeg} build/ 2>/dev/null || true",
  "outputDirectory": "frontend/build",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.+\\.(png|jpg|jpeg|gif|svg|ico|webp|manifest|robots\\.txt))",
      "dest": "/$1",
      "continue": true
    },
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
